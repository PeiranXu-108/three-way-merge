{
  "name": "three-way-diff-editor",
  "version": "0.1.0",
  "description": "Three-column diff editor with merge controls.",
  "license": "MIT",
  "author": "ryanxu",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "src/styles/index.css",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "src", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./src/styles/index.css"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "diff": "^5.0.0"
  },
  "devDependencies": {
    "@types/diff": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "node scripts/generate-styles.js && tsup src/index.ts --format esm,cjs --dts",
    "dev": "node scripts/generate-styles.js && tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "pnpm run build"
  }
}
