{
  "name": "three-way-diff-workspace",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "packageManager": "pnpm>=8.0.0"
  },
  "workspaces": [
    "packages/core",
    "packages/adapter-vue",
    "demo"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter three-way-diff-demo run dev",
    "build": "pnpm --filter three-way-diff-editor run build && pnpm --filter three-way-diff-demo run build"
  },
  "devDependencies": {
    "diff": "^5.0.0",
    "less": "^4.2.0",
    "only-allow": "^1.1.1"
  }
}